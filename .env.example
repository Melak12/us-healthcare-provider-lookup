# -----------------------------------------------------------------------
# Environment variables — copy this file to .env and fill in your values.
# Never commit your real .env file; it is listed in .gitignore.
# -----------------------------------------------------------------------

# Neon Postgres — pooled connection string (used by the app at runtime via
# the @prisma/adapter-neon Driver Adapter in lib/prisma.ts).
# Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Neon Postgres — direct (non-pooled) connection string.
# Used by the Prisma CLI (prisma migrate, prisma db push, etc.) for DDL
# statements that are not compatible with PgBouncer's transaction-pooling mode.
# Format: postgresql://<user>:<password>@ep-HOST-DIRECT.region.aws.neon.tech/<dbname>?sslmode=require
DIRECT_URL="postgresql://USER:PASSWORD@ep-HOST-DIRECT.region.aws.neon.tech/DBNAME?sslmode=require"
